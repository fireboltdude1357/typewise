# Convex writes these values when you link a development deployment.
CONVEX_DEPLOYMENT=
NEXT_PUBLIC_CONVEX_URL=

# Clerk keys for this Next.js app.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Clerk's Frontend API URL. Set this on each Convex deployment with:
# npx convex env set CLERK_JWT_ISSUER_DOMAIN https://your-clerk-domain
CLERK_JWT_ISSUER_DOMAIN=
